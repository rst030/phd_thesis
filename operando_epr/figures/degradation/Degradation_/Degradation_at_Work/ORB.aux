\@writefile{lof}{\contentsline {figure}{\numberline {S12}{\ignorespaces Top four spectra: release of the DiTS monomer from an untreated pDiTS film to the electrolyte (0.1$\,$M solution of Et$_4$NBF$_4$ in Acetonitrile). Field modulation amplitude: 0.10$\,$mT (overmodulated). Bottom: spectrum of DiTS monomer in the electrolyte at a concentration of 100\nobreakspace  {}$\mu $M for comparison. Field modulation amplitude: 0.02$\,$mT.\relax }}{31}\protected@file@percent }
\newlabel{fig:S7_SI}{{S12}{31}}
\@writefile{lof}{\contentsline {figure}{\numberline {S13}{\ignorespaces a) Evolution and component decomposition of cwEPR spectra for a tube-based, 150\nobreakspace  {}CV p-DiTS ORB upon 36 charge-discharge cycles. b) Quantitative analysis of the separated spectral components. $\nu $: 9.4$\,$GHz Mod. Amp: 0.5$\,$mT. Quantitative analysis of the CV curves. c) Cyclic voltammograms of the cell, recorded with respect to Ag/AgCl RE at a rate of 5 mV/s inbetween the EPR scans, in the modified tube inside the microwave resonator. The CV were taken at 5$\,$mV/s, which is 10 times slower than the CV curves taken in the larger beaker, because limited amount of the electrolyte in the modified tube was found to strongly affect the shape and positions of the CV peaks at higher speeds of cycling.\relax }}{32}\protected@file@percent }
\newlabel{fig:S_Deg}{{S13}{32}}
\@writefile{lof}{\contentsline {figure}{\numberline {S14}{\ignorespaces CV curves vs. time for the charge-discharge cycling of a p-DiTS cell. At the scan rate of 5$\,$mV/s each degradation cycle took 200$\,$s. The first CV curve was recorded in a narrower range of potentials. The second CV curve is not shown.\relax }}{33}\protected@file@percent }
\newlabel{fig:S_CV_vs_time}{{S14}{33}}
\@writefile{lof}{\contentsline {figure}{\numberline {S15}{\ignorespaces Degradation of capacity of a p-DiTS film upon 36 charge-discharge cycles. Transferred charge calculated as integrals of the reduction branches of the CV curves. By the last charge-discharge cycle the film can accept 10 times less the charge as in the beginning of the cycling.\relax }}{34}\protected@file@percent }
\newlabel{fig:S_Q_to_Spins}{{S15}{34}}
\@writefile{lof}{\contentsline {figure}{\numberline {S16}{\ignorespaces EPR spectra and spin count for the p-DiTS cell (with electrolyte) before and after the degradation series consisting of 36 charge-discharge cycles. EPR spectrum of the degraded cell with the replaced electrolyte does not show any significant contribution of the three-line component, which indicates that the reduced nitroxide fragments have been released to the electrolyte upon the degradation series.\relax }}{35}\protected@file@percent }
\newlabel{fig:S_wet_degradation_spin_count}{{S16}{35}}
